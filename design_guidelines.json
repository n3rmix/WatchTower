{
  "identity": {
    "name": "Project WATCHTOWER",
    "archetype": "The Tactical Analyst",
    "tone": "Objective, High-Precision, Urgent, Data-Dense",
    "mission": "To provide a real-time, unvarnished view of global conflict data for professionals who need the truth fast."
  },
  "typography": {
    "font_family": {
      "headings": "Barlow Condensed, sans-serif",
      "body": "Manrope, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "scale": {
      "h1": "text-4xl md:text-5xl font-bold tracking-tight uppercase",
      "h2": "text-2xl md:text-3xl font-semibold tracking-tight uppercase",
      "h3": "text-xl font-medium tracking-wide text-muted-foreground",
      "body": "text-sm md:text-base leading-relaxed",
      "data_large": "text-3xl md:text-4xl font-mono font-bold",
      "data_small": "text-xs font-mono tracking-wider"
    },
    "imports": [
      "@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700&family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;700&display=swap');"
    ]
  },
  "colors": {
    "theme": "dark",
    "palette": {
      "background": {
        "default": "#09090b",
        "surface": "#121214",
        "surface_highlight": "#1c1c1f"
      },
      "text": {
        "primary": "#f8fafc",
        "secondary": "#94a3b8",
        "muted": "#64748b"
      },
      "border": {
        "default": "#27272a",
        "active": "#3f3f46"
      },
      "brand": {
        "primary": "#dc2626",
        "secondary": "#ea580c",
        "accent": "#3b82f6"
      },
      "status": {
        "critical": "#ef4444",
        "warning": "#f59e0b",
        "stable": "#10b981",
        "neutral": "#64748b"
      }
    },
    "gradients": {
      "subtle_glow": "radial-gradient(circle at center, rgba(220, 38, 38, 0.15) 0%, transparent 70%)",
      "scanline": "linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0) 50%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.2))"
    }
  },
  "layout": {
    "grid_system": "Bento Grid - Mode B (High Density)",
    "container_style": "cardless or sharp-edged cards",
    "spacing": {
      "dashboard_gap": "gap-2 md:gap-4",
      "section_padding": "p-4 md:p-6",
      "internal_padding": "p-3 md:p-5"
    },
    "border_radius": {
      "default": "rounded-none",
      "button": "rounded-sm"
    }
  },
  "components": {
    "cards": {
      "style": "bg-zinc-950/50 border border-zinc-800 backdrop-blur-sm",
      "hover": "hover:border-zinc-700 transition-colors duration-200"
    },
    "buttons": {
      "primary": "bg-red-700 hover:bg-red-600 text-white font-mono uppercase tracking-wider text-xs px-4 py-2 rounded-sm",
      "secondary": "bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-mono text-xs px-3 py-1 rounded-sm border border-zinc-700"
    },
    "news_ticker": {
      "style": "bg-zinc-950 border-t border-zinc-800 py-2",
      "text_style": "font-mono text-xs text-red-500 uppercase tracking-widest",
      "animation_speed": "slow"
    },
    "charts": {
      "library": "recharts",
      "style": "minimal, thin lines, dark tooltips, no grid lines (or very subtle)"
    }
  },
  "visual_enhancers": {
    "textures": {
      "noise": "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E\")",
      "map_background": "https://images.unsplash.com/photo-1723947842511-139c944ce54e?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2OTF8MHwxfHNlYXJjaHwxfHxkYXJrJTIwZGlnaXRhbCUyMHdvcmxkJTIwbWFwJTIwYWJzdHJhY3R8ZW58MHx8fHwxNzczNjQ3MjQ5fDA&ixlib=rb-4.1.0&q=85"
    },
    "decorations": [
      "Corner accents (plus signs or L-shapes) on cards",
      "Blinking red dot for 'LIVE' status",
      "1px scanlines overlay"
    ]
  },
  "assets": {
    "icons": {
      "library": "lucide-react",
      "style": "stroke-1 md:stroke-[1.5]",
      "usage": "Use simplified icons. Skull for death, Target for conflict, Globe for region."
    },
    "images": {
      "background_texture": "https://images.unsplash.com/photo-1644673640991-f3c4a9dafe9a?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2OTF8MHwxfHNlYXJjaHwyfHxkYXJrJTIwZGlnaXRhbCUyMHdvcmxkJTIwbWFwJTIwYWJzdHJhY3R8ZW58MHx8fHwxNzczNjQ3MjQ5fDA&ixlib=rb-4.1.0&q=85"
    }
  },
  "universal_guidelines": {
    "general": [
      "FORCE DARK MODE: Add 'dark' class to html/body tag permanently.",
      "NO GRADIENTS ON TEXT: Keep text stark white or grey for readability.",
      "Avoid rounded corners > 4px. Sharp edges prefered.",
      "Use 'uppercase' for labels and headers to increase authority.",
      "All interactive elements must have `data-testid`."
    ],
    "accessibility": [
      "Ensure text contrast > 4.5:1 against dark backgrounds.",
      "Do not rely on color alone for status (use icons + text).",
      "Respect prefers-reduced-motion."
    ]
  },
  "instructions_to_main_agent": [
    "Install 'recharts', 'lucide-react', 'react-fast-marquee' immediately.",
    "Set up the global font imports in 'index.css'.",
    "Create a 'Layout' component that enforces the dark theme and grid structure.",
    "Use the provided image URLs as subtle background layers with low opacity (10-20%)."
  ]
}